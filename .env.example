# Frontend (Vite — safe to expose in client bundle; use your Supabase project values)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Local scripts / edge function serve (server-side only — never commit real values)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase Edge Function secrets (set in Dashboard → Edge Functions → Secrets, not in .env for production)
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_VISION_MODEL=baidu/qianfan-ocr-fast:free
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
# OPENROUTER_HTTP_REFERER=https://your-app.example
# OPENROUTER_APP_TITLE=SR&ED GPT
